<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description | default('Danah Travel & Tourism — Professional flight ticketing, visa processing, and tour packages from downtown Riyadh, Saudi Arabia. Book your next journey today.') }}">
  <meta name="keywords" content="travel, tourism, flights, visa, Saudi Arabia, Riyadh, tickets, tour packages, Danah, travel agency">
  <meta name="author" content="Danah Travel & Tourism">
  <meta name="robots" content="index, follow">
  <meta property="og:title" content="{{ title | default('Danah | For Travel and Tourism — Riyadh, Saudi Arabia') }}">
  <meta property="og:description" content="{{ description | default('Your gateway to the world. Modern flight ticketing, visa services, and curated tours from the heart of Riyadh.') }}">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="en_US">
  <meta name="theme-color" content="#3B82F6">
  
  <title>{{ title | default("Danah | For Travel and Tourism") }}</title>

  <link rel="icon" type="image/svg+xml" href="/media/images/logos/favicon.svg">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>

<div id="preloader" role="status" aria-live="polite" aria-label="Loading Danah Travel">
  <div class="pre-logo">Danah</div>
  <div class="pre-bar"><div class="pre-fill"></div></div>
  <div class="pre-label" data-i18n="preloader.label">Loading Experience…</div>
</div>

<div id="cursor-dot" aria-hidden="true"></div>
<div id="cursor-ring" aria-hidden="true"></div>

<a href="/#booking" id="sticky-cta" aria-label="Book a flight" data-i18n-aria-label="sticky.book">
  <i class="fas fa-paper-plane"></i>
  <span class="cta-label" data-i18n="sticky.book">Book a Flight</span>
</a>

<button id="btt" aria-label="Back to top" data-i18n-aria-label="btt"><i class="fas fa-arrow-up"></i></button>

<div id="lightbox" role="dialog" aria-modal="true" aria-label="Image lightbox" data-i18n-aria-label="lightbox">
  <img id="lb-img" src="" alt="">
  <button class="lb-btn" id="lb-close" aria-label="Close" data-i18n-aria-label="lightbox.close"><i class="fas fa-times"></i></button>
  <button class="lb-btn" id="lb-prev" aria-label="Previous image" data-i18n-aria-label="lightbox.prev"><i class="fas fa-chevron-left"></i></button>
  <button class="lb-btn" id="lb-next" aria-label="Next image" data-i18n-aria-label="lightbox.next"><i class="fas fa-chevron-right"></i></button>
</div>

<nav id="nav" role="navigation" aria-label="Primary navigation" data-i18n-aria-label="nav.aria">
  <div class="nav-wrap">
    <!-- ============================================================
		 BRANDING LOGO ENGINE
	============================================================ -->
	<a href="/#hero" class="logo-link">
	  <img src="/media/images/logos/logo.svg" alt="Danah Travel" class="logo-img">
	  <div class="logo-texts">
		<span class="logo-name">DAN<em>AH</em><sup style="font-size:.45em; color:var(--text-muted); vertical-align:super;">™</sup></span>
		<span class="logo-sub" data-i18n="logo_sub">Travel & Tourism</span>
	  </div>
	</a>

    <ul class="nav-links" role="list">
      <li><a href="/#hero" data-i18n="nav.home">Home</a></li>
      <li><a href="/#services" data-i18n="nav.services">Services</a></li>
      <li><a href="/#about" data-i18n="nav.about">About</a></li>
      <li><a href="/#portfolio" data-i18n="nav.destinations">Destinations</a></li>
      <li><a href="/#pricing" data-i18n="nav.pricing">Pricing</a></li>
      <li><a href="/#contact" data-i18n="nav.contact">Contact</a></li>
    </ul>

    <div class="nav-actions">
      <div class="lang-switcher" id="lang-switcher" style="display:flex; align-items:center; gap:6px;">
        <div class="lang-orb" onclick="switchLang('en')" id="lang-en" title="English" data-i18n-title="lang.en" style="width:28px; height:28px; border-radius:50%; overflow:hidden; cursor:pointer; border:2px solid transparent;">
          <img src="/media/images/GB.png" alt="EN" style="width:100%; height:100%; object-fit:cover;">
        </div>
        <div class="lang-orb" onclick="switchLang('ar')" id="lang-ar" title="Arabic" data-i18n-title="lang.ar" style="width:28px; height:28px; border-radius:50%; overflow:hidden; cursor:pointer; border:2px solid transparent;">
          <img src="/media/images/Ar_1.png" alt="AR" style="width:100%; height:100%; object-fit:cover;">
        </div>
      </div>

      <div id="cart-icon" onclick="toggleCart()" style="display:none; position:relative; cursor:pointer; color:var(--text-p); font-size:1.1rem; padding:6px;">
        <i class="fas fa-shopping-cart"></i>
        <span id="cart-count" style="display:none; position:absolute; top:-4px; right:-8px; background:var(--blue); color:#fff; font-size:.65rem; font-weight:700; width:18px; height:18px; border-radius:50%; display:flex; align-items:center; justify-content:center;">0</span>
      </div>

      <div id="user-profile-section" class="user-status-hidden" style="display:none; align-items:center; gap:10px;">
        <a href="/profile.html" class="user-orb" style="display:flex; align-items:center; gap:8px; text-decoration:none; color:var(--text-h); font-weight:600; font-size:.85rem;">
          <i class="fas fa-user-circle" style="font-size:1.4rem; color:var(--blue);"></i>
          <span id="user-display-name">Client</span>
        </a>
        <button onclick="handleLogout()" class="logout-link" style="background:none; border:none; color:var(--text-muted); font-size:.75rem; cursor:pointer; font-weight:500; padding:4px 8px; border-radius:6px;" data-i18n="nav.logout">Logout</button>
      </div>

      <button class="btn-theme" id="theme-toggle" aria-label="Toggle dark mode" data-i18n-aria-label="theme.toggle">
        <i class="fas fa-moon" id="theme-icon"></i>
      </button>

      <a href="/reservation.html" class="btn-blue" style="padding:9px 18px; font-size:.84rem;">
        <i class="fas fa-calendar-check"></i> <span data-i18n="nav.reservation">Reserve</span>
      </a>

      <button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false" data-i18n-aria-label="nav.menuOpen">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation" data-i18n-aria-label="nav.mobileAria">
  <a href="/#hero" class="mob-link" data-i18n="nav.home">Home</a>
  <a href="/#services" class="mob-link" data-i18n="nav.services">Services</a>
  <a href="/#about" class="mob-link" data-i18n="nav.about">About</a>
  <a href="/#portfolio" class="mob-link" data-i18n="nav.destinations">Destinations</a>
  <a href="/#pricing" class="mob-link" data-i18n="nav.pricing">Pricing</a>
  <a href="/#contact" class="mob-link" data-i18n="nav.contact">Contact</a>
  <a href="/reservation.html" class="mob-link btn-blue" style="text-align:center; justify-content:center; margin-top:12px;">
    <i class="fas fa-calendar-check"></i> <span data-i18n="nav.reservation">Reserve Now</span>
  </a>
</nav>

<main>
  {{ content | safe }}
</main>

<footer id="footer" role="contentinfo">
  <div class="container-xl">
    <div class="footer-top">
      <div class="row g-4">
        <div class="col-lg-4 col-md-6">
          <div class="foot-logo">Dan<em>ah</em></div>
          <p class="foot-desc" data-i18n="footer.desc">
            Your trusted travel partner in downtown Riyadh since 2016 — connecting Saudi Arabia to the world through exceptional service and unbeatable value.
          </p>
          <div class="foot-socials">
            <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
            <a href="#" aria-label="Twitter / X"><i class="fab fa-x-twitter"></i></a>
            <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
            <a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
            <a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
            <a href="#" aria-label="TikTok"><i class="fab fa-tiktok"></i></a>
          </div>
        </div>

        <div class="col-lg-2 col-md-6 col-6">
          <div class="foot-head" data-i18n="footer.services">Services</div>
          <ul class="foot-links">
            <li><a href="/#booking"><i class="fas fa-angle-right"></i><span data-i18n="footer.booking">Flight Booking</span></a></li>
            <li><a href="/#services"><i class="fas fa-angle-right"></i><span data-i18n="footer.visa">Visa Services</span></a></li>
            <li><a href="/#pricing"><i class="fas fa-angle-right"></i><span data-i18n="footer.tours">Tour Packages</span></a></li>
            <li><a href="/#services"><i class="fas fa-angle-right"></i><span data-i18n="footer.hotel">Hotel Booking</span></a></li>
            <li><a href="/#services"><i class="fas fa-angle-right"></i><span data-i18n="footer.corp">Corporate Travel</span></a></li>
            <li><a href="/reservation.html"><i class="fas fa-angle-right"></i><span data-i18n="footer.reservations">Reservations</span></a></li>
          </ul>
        </div>

        <div class="col-lg-2 col-md-6 col-6">
          <div class="foot-head" data-i18n="footer.topDests">Top Destinations</div>
          <ul class="foot-links">
            <li><a href="/#portfolio"><i class="fas fa-angle-right"></i>Dubai, UAE</a></li>
            <li><a href="/#portfolio"><i class="fas fa-angle-right"></i>Istanbul, Turkey</a></li>
            <li><a href="/#portfolio"><i class="fas fa-angle-right"></i>London, UK</a></li>
            <li><a href="/#portfolio"><i class="fas fa-angle-right"></i>Paris, France</a></li>
            <li><a href="/#portfolio"><i class="fas fa-angle-right"></i>Maldives</a></li>
            <li><a href="/#portfolio"><i class="fas fa-angle-right"></i>Tokyo, Japan</a></li>
          </ul>
        </div>

        <div class="col-lg-4 col-md-6">
          <div class="foot-head" data-i18n="footer.newsletter">Stay in the Loop</div>
          <p style="font-size:.855rem;color:rgba(255,255,255,.4);margin-bottom:16px;line-height:1.65;" data-i18n="footer.newsletter_desc">
            Subscribe for exclusive deals, early-bird offers, and travel inspiration delivered directly to your inbox.
          </p>
          <div class="nl-wrap">
            <input type="email" class="nl-input" data-i18n-placeholder="footer.placeholder" placeholder="Enter your email address…" aria-label="Email for newsletter">
            <button class="nl-btn" data-i18n="footer.subscribe">Subscribe</button>
          </div>
          <p style="font-size:.74rem;color:rgba(255,255,255,.25);margin-top:10px;" data-i18n="footer.nospam">
            No spam, ever. Unsubscribe at any time.
          </p>
          <div style="display:flex;gap:12px;margin-top:20px;flex-wrap:wrap;">
            <div style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.09);padding:7px 12px;border-radius:8px;font-size:.72rem;color:rgba(255,255,255,.4);display:flex;align-items:center;gap:6px;">
              <i class="fas fa-shield-halved" style="color:var(--blue);"></i> <span data-i18n="footer.sta">STA Licensed</span>
            </div>
            <div style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.09);padding:7px 12px;border-radius:8px;font-size:.72rem;color:rgba(255,255,255,.4);display:flex;align-items:center;gap:6px;">
              <i class="fas fa-certificate" style="color:var(--amber);"></i> <span data-i18n="footer.iata">IATA Accredited</span>
            </div>
            <div style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.09);padding:7px 12px;border-radius:8px;font-size:.72rem;color:rgba(255,255,255,.4);display:flex;align-items:center;gap:6px;">
              <i class="fas fa-lock" style="color:var(--green);"></i> <span data-i18n="footer.ssl">SSL Secured</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="footer-bot">
      <div class="foot-copy" data-i18n="footer.copy">
        © 2026 Danah Travel & Tourism. All rights reserved. | STA License #STA-RUH-2016-0442
      </div>
      <div class="foot-legal">
        <a href="#" data-i18n="footer.privacy">Privacy Policy</a>
        <a href="#" data-i18n="footer.terms">Terms of Service</a>
        <a href="#" data-i18n="footer.cookies">Cookie Policy</a>
      </div>
    </div>
  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/assets/js/api.js"></script>
<script src="/assets/js/core.js"></script>

{# Only load the full homepage script on the actual homepage #}
{% if includeHomepageScript %}
  <script src="/assets/js/index-page.js"></script>
{% endif %}

{# Page‑specific scripts (login, contact, reservation, dashboard) #}
{% if pageScript %}
  <script src="{{ pageScript }}"></script>
{% endif %}
</html>